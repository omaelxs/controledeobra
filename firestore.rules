rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──
    function isAuth() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdminOrDev() {
      return isAuth() && getUserRole() in ['admin', 'dev'];
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ── Users ──
    match /users/{uid} {
      allow read: if isAuth();

      // Users can update their own profile (displayName, photoURL, online, lastSeen)
      allow update: if isOwner(uid) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['displayName', 'photoURL', 'online', 'lastSeen']);

      // Only admin can change roles and obra assignment
      allow update: if isAdminOrDev() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['role', 'obraIdPermitida']);

      // Auto-create on first login
      allow create: if isOwner(uid) &&
        request.resource.data.role in ['user', 'admin'];
    }

    // ── Obras ──
    match /obras/{obraId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdminOrDev();

      // Sub-collections
      match /pavimentos/{pavId} {
        allow read: if isAuth();
        allow create, update, delete: if isAdminOrDev();
      }
    }

    // ── FVS (legacy) ──
    match /fvs/{fvsId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdminOrDev();
    }

    // ── FVS Modelos (templates) ──
    match /fvsModelos/{modeloId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdminOrDev();
    }

    // ── FVS Aplicadas (instâncias) ──
    match /fvsAplicadas/{aplicadaId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAdminOrDev();
    }

    // ── NC ──
    match /nc/{ncId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdminOrDev();
    }

    // ── Responsáveis ──
    match /responsaveis/{respId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdminOrDev();
    }

    // ── Vistorias ──
    match /vistorias/{vistoriaId} {
      allow read: if isAuth();
      // Qualquer usuário autenticado pode criar vistoria
      allow create: if isAuth() &&
        request.resource.data.keys().hasAll(['obraId', 'pavimentoId', 'apartamentoId', 'scopes']) &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.status in ['pendente', 'aprovado', 'reprovado'];
      // Apenas admin/dev podem editar/deletar
      allow update, delete: if isAdminOrDev();
    }

    // ── Checklists ──
    match /checklists/{checklistId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdminOrDev();
    }

    // ── Logs (append-only — NINGUÉM pode editar ou excluir) ──
    match /logs/{logId} {
      allow read: if isAdminOrDev();
      // Todos autenticados podem CRIAR logs, mas arquivo automaticamente é imutável
      allow create: if isAuth() &&
        request.resource.data.keys().hasAll(['userId', 'userEmail', 'action', 'target', 'timestamp']) &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.immutable == true;
      // NUNCA permitir edição ou deleção
      allow update, delete: if false;
    }

    // ── Notifications ──
    match /notifications/{notifId} {
      allow read: if isAuth();
      // Apenas admin/dev podem criar notificações
      allow create: if isAdminOrDev() &&
        request.resource.data.keys().hasAll(['title', 'message', 'type', 'createdBy', 'timestamp']) &&
        request.resource.data.type in ['info', 'warning', 'success', 'alert'];
      // Qualquer usuário autenticado pode marcar como lida (readBy)
      allow update: if isAuth() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['readBy']);
      // Ninguém pode deletar notificações
      allow delete: if false;
    }

    // ── Chat General ──
    match /chat_general/{msgId} {
      allow read: if isAuth();
      allow create: if isAuth() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.keys().hasAll(['userId', 'text', 'timestamp']);
      // Ninguém pode editar or deletar mensagens
      allow update, delete: if false;
    }

    // ── Chat Moderators ──
    match /chat_moderators/{msgId} {
      allow read: if isAdminOrDev();
      allow create: if isAdminOrDev() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.keys().hasAll(['userId', 'text', 'timestamp']);
      // Ninguém pode editar or deletar mensagens
      allow update, delete: if false;
    }

    // ── Deny all other access ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

